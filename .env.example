# =============================================================================
# IndusAI Technology E-Commerce Platform — Environment Variable Template
# -----------------------------------------------------------------------------
# Copy this file to `.env` (backend) and fill in real values.
# NEVER commit the real `.env` file. This template has NO secrets.
# Frontend uses a separate frontend/.env with VITE_* keys (see bottom section).
# =============================================================================

# ───────────────────────────── App ──────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ───────────────────────── Database (Neon) ──────────────────────────────
# Needed: Phase 2. Get from https://neon.tech → project → connection string.
DATABASE_URL=

# ───────────────────────────── JWT ──────────────────────────────────────
# Needed: Phase 2. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Seed owner account (Phase 2.1 seed.ts)
SEED_OWNER_EMAIL=owner@indusai.pk
SEED_OWNER_PASSWORD=

# ─────────────────────── Cloudinary (Images) ────────────────────────────
# Needed: Phase 3. Get from https://cloudinary.com dashboard.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─────────────────────── SendGrid (Email/OTP) ───────────────────────────
# Needed: Phase 2. Get from https://sendgrid.com → Settings → API Keys.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ─────────────────────── Twilio (SMS OTP — optional) ────────────────────
# Needed: Phase 11 (optional). Email OTP is primary.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_PHONE_NUMBER=

# ─────────────────────── Stripe (Card Payments) ─────────────────────────
# Needed: Phase 10. Get from https://stripe.com → Developers → API Keys.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─────────────────────── JazzCash (PK Wallet) ───────────────────────────
# Needed: Phase 10. Sandbox is instant. https://developer.jazzcash.com.pk
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_SANDBOX_URL=https://sandbox.jazzcash.com.pk/ApplicationAPI/API

# ─────────────────────── Easypaisa (PK Wallet) ──────────────────────────
# Needed: Phase 10. ⚠️ 2-5 business-day onboarding — request EARLY.
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
EASYPAISA_SANDBOX_URL=https://easypay.easypaisa.com.pk/tpg

# ─────────────────────── OpenAI (AI features) ───────────────────────────
# Needed: Phase 9. Get from https://platform.openai.com → API Keys.
OPENAI_API_KEY=

# ─────────────────────── Sentry (Error Monitoring) ──────────────────────
# Needed: Phase 14. Create separate backend + frontend projects.
SENTRY_DSN_BACKEND=
SENTRY_DSN_FRONTEND=

# =============================================================================
# FRONTEND (place these in frontend/.env — must be prefixed VITE_)
# =============================================================================
# VITE_API_URL=http://localhost:3000/api
# VITE_STRIPE_PUBLISHABLE_KEY=
# VITE_CLOUDINARY_CLOUD_NAME=
# VITE_SENTRY_DSN_FRONTEND=
