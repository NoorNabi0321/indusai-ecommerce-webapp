{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "description": "IndusAI Technology — Express + TypeScript API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "db:push": "dotenv -e ../.env -- prisma db push",
    "db:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "db:generate": "dotenv -e ../.env -- prisma generate",
    "db:seed": "dotenv -e ../.env -- ts-node --transpile-only prisma/seed.ts",
    "db:studio": "dotenv -e ../.env -- prisma studio",
    "db:reset": "dotenv -e ../.env -- prisma migrate reset"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@sendgrid/mail": "^8.1.4",
    "@sentry/node": "^8.47.0",
    "@tensorflow/tfjs": "^4.22.0",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "nodemailer": "^8.0.10",
    "otplib": "^12.0.1",
    "stripe": "^17.5.0",
    "uuid": "^11.0.3",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prisma": "^6.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
