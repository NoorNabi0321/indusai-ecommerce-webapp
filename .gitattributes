# Normalize line endings: store as LF in the repo, check out native on Windows.
* text=auto eol=lf

# Explicit text types
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.html text eol=lf
*.prisma text eol=lf

# Binary assets
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
